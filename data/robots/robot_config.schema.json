{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "robot_config.schema.json",
  "title": "RobotConfig",
  "description": "Per-robot configuration for the radio-robot system.",
  "$comment": "The custom `firmware` keyword on a property is the single source of truth that maps a JSON value to a firmware RobotConfig field. It has: `field` (the C++ RobotConfig member emitted into source/robot/DefaultConfig.cpp by scripts/gen_default_config.py), `set_key` (the live SET/GET wire key from source/robot/ConfigRegistry.cpp, used by the host runtime push; omit when the value is applied a special way, e.g. OTOS scalars via OL/OA), and `kind` (float | int | float_as_int | bool — how to render the literal). A property with `firmware` is baked into the generated firmware default AND pushed live on connect; one without is host-side only.",
  "type": "object",
  "required": ["schema_version", "identity"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2,
      "description": "Config schema version. 1 = legacy (no rotation_gain_neg fields). 2 = current."
    },

    "identity": {
      "type": "object",
      "required": ["robot_name", "uid"],
      "additionalProperties": false,
      "properties": {
        "robot_name":     { "type": "string" },
        "uid":            { "type": "string" },
        "hardware_model": { "type": "string" },
        "common_name":    { "type": "string" }
      }
    },

    "connection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "device_announcement_name": { "type": "string" },
        "serial_last_6":            { "type": "string", "pattern": "^[0-9a-f]{6}$" },
        "i2c_addresses": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    },

    "vision": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "robot_tag_id": { "type": "integer", "minimum": 0 },
        "tag_offset_mm": { "$ref": "#/$defs/OffsetXYYaw" },
        "camera_distance_scale": { "type": "number", "description": "Multiplicative correction for camera-measured distances. Host-side only." }
      }
    },

    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "drive_axle_offset_mm":    { "$ref": "#/$defs/OffsetXY" },
        "odometry_offset_mm":      { "$ref": "#/$defs/OffsetXYYaw" },
        "odometry_chip_upside_down": { "type": "boolean" },
        "trackwidth": {
          "type": ["number", "null"],
          "description": "Wheel track width (mm).",
          "firmware": { "field": "trackwidthMm", "set_key": "tw", "kind": "float_as_int" }
        },
        "wheelbase_mm":            { "type": ["number", "null"] }
      }
    },

    "wheels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wheel_diameter_mm": { "type": ["number", "null"] },
        "ticks_per_rev":     { "type": ["number", "null"] },
        "ticks_per_mm":      { "type": ["number", "null"] }
      }
    },

    "encoders": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "has_encoders":  { "type": "boolean" },
        "encoder_count": { "type": "integer", "minimum": 0 }
      }
    },

    "drive": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "motor_deadband":       { "type": ["number", "null"] },
        "max_cmd":              { "type": ["number", "null"] },
        "cmd_to_mm_per_s":      { "type": ["number", "null"] },
        "max_drive_mm_s":       { "type": ["number", "null"] },
        "max_turn_deg_s":       { "type": ["number", "null"] },
        "min_drive_mm_s":       { "type": ["number", "null"] },
        "crawl_threshold_mm_s": { "type": ["number", "null"] },
        "crawl_cmd":            { "type": ["number", "null"] }
      }
    },

    "gripper": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "has_gripper":       { "type": "boolean" },
        "gripper_offset_mm": {
          "oneOf": [
            { "$ref": "#/$defs/OffsetXY" },
            { "type": "null" }
          ]
        }
      }
    },

    "peripherals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "laser_port": {
          "description": "Digital port (J1..J4) the line laser is wired to.",
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 4
        }
      }
    },

    "calibration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "otos_angular_scale": {
          "type": "number",
          "description": "OTOS angular scale multiplier (e.g. 0.987). Programmed into the OTOS chip at boot from the baked default; live update via OL/OA, not SET.",
          "firmware": { "field": "otosAngularScale", "kind": "float" }
        },
        "otos_linear_scale": {
          "type": "number",
          "description": "OTOS linear scale multiplier (e.g. 1.050). Programmed into the OTOS chip at boot from the baked default; live update via OL/OA, not SET.",
          "firmware": { "field": "otosLinearScale", "kind": "float" }
        },
        "mm_per_wheel_deg_left": {
          "type": ["number", "null"],
          "description": "Per-wheel encoder calibration: mm of travel per degree of wheel rotation (left wheel).",
          "firmware": { "field": "mmPerDegL", "set_key": "ml", "kind": "float" }
        },
        "mm_per_wheel_deg_right": {
          "type": ["number", "null"],
          "description": "Per-wheel encoder calibration: mm of travel per degree of wheel rotation (right wheel).",
          "firmware": { "field": "mmPerDegR", "set_key": "mr", "kind": "float" }
        },
        "rotational_slip": {
          "type": ["number", "null"],
          "description": "Body-rotation efficiency: actual_body_rotation / no_slip_estimate. 1.0 = no slip.",
          "firmware": { "field": "rotationalSlip", "set_key": "rotSlip", "kind": "float" }
        },
        "rotation_gain": {
          "type": ["number", "null"],
          "description": "Linear correction gain for CCW (positive) turns: actual_deg = gain * commanded + offset.",
          "firmware": { "field": "rotationGainPos", "set_key": "rotGainPos", "kind": "float" }
        },
        "rotation_offset_deg": {
          "type": ["number", "null"],
          "description": "Linear correction offset (deg) for CCW (positive) turns.",
          "firmware": { "field": "rotationOffsetDeg", "set_key": "rotOffPos", "kind": "float" }
        },
        "rotation_gain_neg": {
          "type": ["number", "null"],
          "description": "Linear correction gain for CW (negative) turns. Falls back to rotation_gain when null.",
          "firmware": { "field": "rotationGainNeg", "set_key": "rotGainNeg", "kind": "float" }
        },
        "rotation_offset_deg_neg": {
          "type": ["number", "null"],
          "description": "Linear correction offset (deg) for CW (negative) turns. Falls back to rotation_offset_deg when null.",
          "firmware": { "field": "rotationOffsetDegNeg", "set_key": "rotOffNeg", "kind": "float" }
        },
        "ekf_r_otos_theta": {
          "type": ["number", "null"],
          "description": "EKF OTOS heading measurement noise variance (rad^2). Default ~0.01 ≈ (5.7°)². Tune up if OTOS heading is noisier on carpet.",
          "firmware": { "field": "ekfROtosTheta", "set_key": "ekfRHead", "kind": "float" }
        }
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "description": "Velocity-loop PID, cross-wheel coupling, and motion-planning tunables. Each field with a `firmware` mapping is baked into the generated default and pushed via SET on connect; firmware default kept when a field is null.",
      "properties": {
        "vel_kp":        { "type": ["number", "null"], "description": "Velocity PID proportional gain.", "firmware": { "field": "velKp", "set_key": "vel.kP", "kind": "float" } },
        "vel_ki":        { "type": ["number", "null"], "description": "Velocity PID integral gain.", "firmware": { "field": "velKi", "set_key": "vel.kI", "kind": "float" } },
        "vel_kff":       { "type": ["number", "null"], "description": "Velocity feed-forward coefficient.", "firmware": { "field": "velKff", "set_key": "vel.kFF", "kind": "float" } },
        "vel_imax":      { "type": ["number", "null"], "description": "Integrator anti-windup clamp, PWM%.", "firmware": { "field": "velIMax", "set_key": "vel.iMax", "kind": "float" } },
        "vel_kaw":       { "type": ["number", "null"], "description": "Back-calculation anti-windup gain, 1/s.", "firmware": { "field": "velKaw", "set_key": "vel.kAw", "kind": "float" } },
        "vel_filt":      { "type": ["number", "null"], "description": "Velocity EMA smoothing weight.", "firmware": { "field": "velFiltAlpha", "set_key": "vel.filt", "kind": "float" } },
        "sync":          { "type": ["number", "null"], "description": "Cross-wheel ratio coupling gain.", "firmware": { "field": "syncGain", "set_key": "sync", "kind": "float" } },
        "min_wheel_mms": { "type": ["number", "null"], "description": "Low-speed integrator deadband, mm/s.", "firmware": { "field": "minWheelMms", "set_key": "minWheelMms", "kind": "float" } },
        "turn_gate":     { "type": ["number", "null"], "description": "Turn-in-place gate (deg): G/go-to pre-rotates in place until the bearing to the target is within this angle, then arcs. Sim sweep optimum ~35 (host_tests/arc_gate_sweep.ipynb).", "firmware": { "field": "turnInPlaceGate", "set_key": "turnGate", "kind": "float_as_int" } },
        "arrive_tol_mm": { "type": ["number", "null"], "description": "G arrival tolerance radius (mm): POSITION stop fires when the robot centre is within this disc of the target. Default 5; widened to 25 for carpet (D8 027-004).", "firmware": { "field": "arriveTolMm", "set_key": "arriveTol", "kind": "float" } },
        "max_rot_accel_dps2": { "type": ["number", "null"], "description": "Host-side turn ramp: max rotational acceleration, deg/s^2 (default 300). Host-side only — no firmware mapping." }
      }
    }
  },

  "$defs": {
    "OffsetXY": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "OffsetXYYaw": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x":       { "type": "number" },
        "y":       { "type": "number" },
        "yaw_rad": { "type": "number" }
      }
    }
  }
}
