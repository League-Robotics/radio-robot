build
# Ignore vendored-library CONTENTS at any depth (src/libraries/, plus
# src/archive/wedgelab/libraries/), but not a co-located design-doc-set
# DESIGN.md that documents the directory itself -- the bare "libraries"
# form used before this carve-out ignores the directory ENTRY too, which
# makes a file inside it un-negatable (git: "It is not possible to
# re-include a file if a parent directory of that file is excluded").
# "**/libraries/**" ignores contents only, so the DESIGN.md negation
# below actually takes effect.
**/libraries/**
!**/libraries/DESIGN.md
.yotta.json
yotta_modules
yotta_targets
*.swp
*~
Makefile
*.hex
*.DS_Store
.vscode
*.uf2
*.bin
pxtapp
buildcache.json
*.pyc
.venv
__pycache__

# clangd's background-index cache (regenerated on demand).
.cache/

# --- CMake / generated build directories ---
# Build dirs created by tooling/agents: build/, build_prod2/, build_prod_test/, etc.
# (build_*/ uses an underscore so it never matches utils/cmake/buildtools/ sources)
build_*/
cmake-build-*/

# --- Test GUI session recordings (generated output, not source) ---
# Same directory-vs-contents carve-out as the libraries/ block above, so
# src/recordings/DESIGN.md can be tracked while latest.jsonl stays ignored.
**/recordings/**
!**/recordings/DESIGN.md

# --- aprilcam server data (we are a CLIENT; aprilcam owns this) ---
# aprilcam's data_dir is relative ("data/aprilcam"), so running its daemon or
# our client tooling from this repo root makes it write logs/overlays here.
# Never check that in — the real aprilcam data dir lives outside this repo.
data/aprilcam/

# Generated firmware version header (scripts/gen_version.py, from pyproject.toml).
src/firm/types/version_generated.h

# CMake-generated files, wherever they land in the tree.
# These names are always generated and are never checked-in source
# (real .cmake modules live under utils/cmake/ and are unaffected).
CMakeCache.txt
CMakeFiles/
CMakeScripts/
CMakeRuleHashes.txt
cmake_install.cmake
cmake_uninstall.cmake
CTestTestfile.cmake
Makefile.cmake
TargetDirectories.txt
install_manifest.txt
compile_commands.json
DEPFILE
_deps/

# wedgelab standalone project artifacts
wedgelab/build/
wedgelab/out/
wedgelab/MICROBIT.hex
wedgelab/MICROBIT.bin

# tests/bench/ HITL run artifacts (CSV logs from pid_hold_speed.py,
# ratio_governor_curve.py, etc.) -- paths are recorded in ticket results,
# not committed.
src/tests/bench/out/

# tests/sim/system/ rendered-trace PNGs (render_tour_trace.py, ticket 086-004)
# -- regenerable build artifacts, same rationale as src/tests/bench/out/ above.
src/tests/sim/system/out/

# SQLite WAL-mode sidecar files for the CLASI state DB (.clasi/.clasi.db) --
# transient; the checkpointed .clasi.db is the tracked source of truth.
.clasi/*.db-wal
.clasi/*.db-shm
