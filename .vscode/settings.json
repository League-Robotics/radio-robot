{
    // Single venv at the repo root since 2026-07-02 (host/.venv was folded in).
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

    // The Microsoft C/C++ IntelliSense parser (EDG) cannot parse the GCC 15.2
    // headers this project's toolchain ships, producing phantom "expected a ';'"
    // squiggles on valid code. Disable it and use clangd (Apple clang 21) instead,
    // which parses GCC 15 headers correctly. cpptools is still used for debugging.
    "C_Cpp.intelliSenseEngine": "disabled",

    "clangd.path": "/usr/bin/clangd",
    "clangd.arguments": [
        // Read the real per-file flags the build uses — from a stable merged
        // copy OUTSIDE the repo, because rebuilds regenerate
        // build/compile_commands.json and (when codal.json pointed at the
        // wedge lab) repeatedly dropped every source/ entry, causing the
        // recurring phantom-squiggle storms. Refresh this copy from
        // build/compile_commands.json after a production build.
        "--compile-commands-dir=/Users/eric/.cache/clangd-cdb/radio-robot-elite",
        // Let clangd run the ARM GCC driver to import its newlib + libstdc++
        // system include paths (so cross-target headers resolve correctly).
        "--query-driver=/opt/homebrew/bin/arm-none-eabi-*",
        "--background-index",
        "--header-insertion=never",
        "--pch-storage=memory"
    ]
}
